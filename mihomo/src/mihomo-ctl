// ─── 命令：upgrade ─────────────────────────────────────────────
async function cmdUpgradeMihomo() {
  console.log(c.bold('\n── Mihomo 内核升级 ──────────────────────────'));
  console.log(c.dim(`  平台: ${P.name} / ${process.arch === 'arm64' ? 'arm64' : 'amd64'}\n`));

  // 1. 查询最新版本
  process.stdout.write('  查询最新版本... ');
  let latest;
  try {
    const out = run(`curl -sf --max-time 10 ${resolveProxyArg()} "https://api.github.com/repos/MetaCubeX/mihomo/releases/latest"`);
    if (!out) { console.log(c.red('获取失败，检查网络')); return; }
    latest = JSON.parse(out).tag_name;
  } catch (e) { console.log(c.red(`失败: ${e.message}`)); return; }

  const verOut  = run(`"${BIN}" -v 2>/dev/null`);
  const current = (verOut.match(/v[\d]+\.[\d]+\.[\d]+(?:-[a-z0-9]+)?/i) || [])[0] || '';
  console.log(`最新 ${c.green(latest)}  当前 ${current === latest ? c.green(current) : c.yellow(current || '未检测')}`);
  if (current === latest) { console.log(c.green('  已是最新版本')); return; }

  // 2. 构建下载地址
  const osMap  = { darwin: 'darwin', linux: 'linux', freebsd: 'freebsd', win32: 'windows' };
  const osName = osMap[process.platform] || 'linux';
  const arch   = process.arch === 'arm64' ? 'arm64' : 'amd64';
  const { url, tmpPkg, tmpBin, bkBin, unzipDir } = P.upgradeAsset(osName, arch, latest);

  // 3. 预下载（进程仍在运行中，最大化在线时间）
  const wasRunning = await isRunning();
  if (wasRunning) console.log(c.green(`  ✓ 进程运行中，预下载中（代理不中断）...`));
  console.log(c.dim(`    ${url}`));
  run(`curl -4 -L -C - --max-time 180 ${resolveProxyArg()} -o "${tmpPkg}" "${url}" 2>/dev/null`);
  if (!fs.existsSync(tmpPkg) || fs.statSync(tmpPkg).size < 500000) {
    console.log(c.red('✗ 下载失败或文件过小，请检查网络'));
    try { fs.unlinkSync(tmpPkg); } catch {}
    return;
  }

  try { P.extractAsset(tmpPkg, tmpBin, { unzipDir }); }
  catch (e) { console.log(c.red(`✗ 解压失败: ${e.message}`)); return; }
  console.log(c.green('  ✓ 下载解压完成'));

  // 4. 自动备份配置（升级前保护）
  const ts        = new Date().toISOString().slice(0, 19).replace(/[T:]/g, '-');
  const backupDir = path.join(CONFIG_DIR, 'backups', ts);
  fs.mkdirSync(backupDir, { recursive: true });
  if (fs.existsSync(CONFIG)) {
    fs.copyFileSync(CONFIG, path.join(backupDir, 'config.yaml'));
    console.log(c.dim(`  配置已备份: ${backupDir}/config.yaml`));
  }

  // 5. 停止服务（停机从这里开始，已下载完，停机时间极短）
  if (wasRunning) {
    process.stdout.write('  停止服务... ');
    P.stopProcess();
    await new Promise(r => setTimeout(r, 800));
    console.log('done');
  }

  // 6. 备份旧二进制 + 原子替换新二进制
  P.backupBin(bkBin);
  try {
    P.installBin(tmpBin);
  } catch (e) {
    console.log(c.red(`✗ 安装失败: ${e.message}`));
    P.rollbackBin(bkBin);
    console.log(c.yellow('  已回滚旧版本'));
    if (wasRunning) { P.startProcess(); await new Promise(r => setTimeout(r, 1500)); }
    return;
  }

  // 7. 启动新版本并验证
  if (wasRunning) {
    process.stdout.write('  启动新版本... ');
    P.startProcess();
    await new Promise(r => setTimeout(r, 1800));
    if (await isRunning()) {
      const newOut = run(`"${BIN}" -v 2>/dev/null`);
      const newVer = (newOut.match(/v[\d]+\.[\d]+\.[\d]+(?:-[a-z0-9]+)?/i) || [])[0] || latest;
      console.log('done');
      console.log(c.bold('\n── 升级结果 ──────────────────────────────────'));
      console.log(c.green(`  ✓ 升级成功`));
      console.log(`     ${c.yellow(current || '?')} → ${c.green(newVer)}`);
      console.log(c.dim(`  停机时间: ≈ 3s（预下载完成后才停机）`));
      console.log(c.dim(`  配置备份: ${backupDir}/`));
      console.log(c.dim(`  回滚命令: ${P.upgradeRollbackHint(bkBin)}`));
    } else {
      console.log(c.red('\n  ✗ 启动失败，自动回滚...'));
      P.stopProcess();
      P.rollbackBin(bkBin);
      P.startProcess();
      await new Promise(r => setTimeout(r, 1500));
      if (await isRunning()) console.log(c.yellow('  ⚠ 已回滚到旧版本并重启'));
      else console.log(c.red('  ✗ 回滚失败，请手动处理'));
      return;
    }
  } else {
    const newOut = run(`"${BIN}" -v 2>/dev/null`);
    const newVer = (newOut.match(/v[\d]+\.[\d]+\.[\d]+(?:-[a-z0-9]+)?/i) || [])[0] || latest;
    console.log(c.bold('\n── 升级结果 ──────────────────────────────────'));
    console.log(c.green(`  ✓ 升级完成（服务未运行，下次启动生效）`));
    console.log(`     ${c.yellow(current || '?')} → ${c.green(newVer)}`);
    console.log(c.dim(`  配置备份: ${backupDir}/`));
    console.log(c.dim(`  回滚命令: ${P.upgradeRollbackHint(bkBin)}`));
  }
}


// ─── 命令：upgrade（升级 mihomo-ctl 自身，从 GitHub Release）───
async function cmdUpgrade() {
  console.log(c.bold('\n── mihomo-ctl 自升级 ─────────────────────────'));
  console.log(c.dim(`  当前版本: v${VERSION}`));
  console.log(c.dim(`  来源: GitHub Release (${GITHUB_REPO})\n`));

  // 1. 查询最新 ctl release
  process.stdout.write('  查询最新版本... ');
  let latest, latestTag;
  try {
    const out = run(`curl -sf --max-time 10 ${resolveProxyArg()} "https://api.github.com/repos/${GITHUB_REPO}/releases?per_page=50"`);
    if (!out) { console.log(c.red('无响应，检查网络')); return; }
    const releases = JSON.parse(out);
    const parseVF = v => v.split('.').map(Number);
    const cmpVF = (a, b) => { for (let i = 0; i < 3; i++) { if (a[i] !== b[i]) return a[i] - b[i]; } return 0; };
    let bestVer = null, bestTag = null;
    for (const r of releases) {
      if (!r.tag_name || !r.tag_name.startsWith('mihomo-ctl-v')) continue;
      const ver = r.tag_name.replace('mihomo-ctl-v', '');
      if (!bestVer || cmpVF(parseVF(ver), parseVF(bestVer)) > 0) { bestVer = ver; bestTag = r.tag_name; }
    }
    if (!bestVer) { console.log(c.yellow('未找到 mihomo-ctl release，请先发布')); return; }
    latestTag = bestTag;
    latest    = bestVer;
  } catch (e) { console.log(c.red(`失败: ${e.message}`)); return; }
  console.log(`最新 ${c.green('v' + latest)}`);

  // 2. 版本比较
  const parseVer = v => v.split('.').map(Number);
  const [ra, rb, rc] = parseVer(latest);
  const [la, lb, lc] = parseVer(VERSION);
  const isNewer = ra > la || (ra === la && rb > lb) || (ra === la && rb === lb && rc > lc);
  if (!isNewer) {
    console.log(latest === VERSION ? c.green('  ✓ 已是最新版本') : c.yellow(`  ⚠ 远端 v${latest} 比当前 v${VERSION} 旧，跳过`));
    return;
  }

  // 3. 构建下载地址
  const osMap  = { darwin: 'darwin', linux: 'linux', freebsd: 'linux' };
  const archMap = { arm64: 'arm64', x64: 'x64' };
  const osName  = osMap[process.platform] || 'linux';
  const arch    = archMap[process.arch] || process.arch;
  const assetName = `mihomo-ctl-${latest}-${osName}-${arch}.gz`;
  const url = `https://github.com/${GITHUB_REPO}/releases/download/${latestTag}/${assetName}`;

  const tmpGz  = path.join(TMP, assetName);
  const tmpBin = path.join(TMP, 'mihomo-ctl-new');

  process.stdout.write(`  下载 ${assetName}... `);
  try {
    execSync(`curl -fsSL --max-time 60 ${resolveProxyArg()} -o "${tmpGz}" "${url}"`, { stdio: 'pipe' });
  } catch (e) {
    console.log(c.red('失败'));
    console.log(c.dim(`  URL: ${url}`));
    console.log(c.dim(`  ${e.message}`));
    return;
  }
  console.log('done');

  // 4. 解压
  try {
    execSync(`gunzip -c "${tmpGz}" > "${tmpBin}"`, { stdio: 'pipe' });
    fs.chmodSync(tmpBin, 0o755);
    fs.unlinkSync(tmpGz);
  } catch (e) { console.log(c.red(`✗ 解压失败: ${e.message}`)); return; }

  // 5. 替换安装
  const self = process.argv[1];
  const bak  = `${self}.bak-v${VERSION}`;
  try {
    P.installSelf(tmpBin, self, bak);
  } catch (e) {
    console.log(c.red(`✗ 替换失败: ${e.message}`));
    return;
  }

  console.log(c.bold('\n── 升级结果 ──────────────────────────────────'));
  console.log(c.green('  ✓ mihomo-ctl 升级成功'));
  console.log(`     ${c.yellow('v' + VERSION)} → ${c.green('v' + latest)}`);
  console.log(c.dim(`  备份: ${bak}`));
  console.log(c.dim(`  回滚: ${P.selfRollbackHint(bak, self)}`));
}

