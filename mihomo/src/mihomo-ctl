// 检测占用 API 的内核是否是「我们自己的」mihomo（-d CONFIG_DIR）
// 用于排除 ClashX Meta / Clash Verge 等占用 9090 端口造成的 isRunning 误判
function ownKernelRunning() {
  if (IS_WIN) return true; // Windows 进程名/参数检测不可靠，跳过严格校验
  const hit = run(`pgrep -f "mihomo -d ${CONFIG_DIR}" 2>/dev/null`)
           || run(`ps -axww -o pid=,command= 2>/dev/null | grep -- "-d ${CONFIG_DIR}" | grep mihomo | grep -v grep`);
  return !!(hit && hit.trim());
}

async function isRunning() {
  try {
    const res = await apiGet('/version');
    // 验证是真正的 Mihomo API（ClashX 等其他程序占用 9090 时返回 401 {"message":"Unauthorized"}）
    const apiUp = typeof res === 'object' && typeof res.version === 'string' && res.version.length > 0;
    if (!apiUp) return false;
    // 进一步确认占用 9090 的是我们自己的内核，而非 ClashX/Verge 等第三方核心
    return ownKernelRunning();
  } catch { return false; }
}

// 异步获取出口 IP（并发执行，不阻塞其他渲染）
// url 默认走国际站 ipify（适合经代理出口）；直连探测传国内站避免被墙超时
function fetchExitIp(curlArgs, url = 'https://api.ipify.org') {
  return new Promise(resolve => {
    exec(`curl -sf --max-time 3 ${curlArgs} ${url} 2>/dev/null`, (err, out) => {
      if (err) return resolve(null);
      // 仅提取 IPv4，过滤掉可能的 HTML/JSON 包裹
      const ip = (out || '').match(/\b\d{1,3}(?:\.\d{1,3}){3}\b/);
      resolve(ip ? ip[0] : null);
    });
  });
}

async function cmdStatus() {
  console.log(c.bold('\n── Mihomo 状态 ──────────────────────────────'));

  const autostartStr = P.isAutostartEnabled() ? c.green('开机自启: 已启用') : c.dim('开机自启: 已禁用');

  const running = await isRunning();
  if (!running) {
    const binOut = run(`"${BIN}" -v 2>/dev/null`);
    const binVer = (binOut.match(/v[\d.]+(?:-[a-z0-9]+)?/i) || [])[0] || '';
    const verStr = binVer ? `  ${c.dim('已安装: ' + binVer)}` : '';
    console.log(c.red('● 未运行') + `${verStr}   ctl: v${VERSION}   ${autostartStr}`);
    P.extraOfflineStatus();
    return;
  }

  // 尽早并发发起出口 IP 检测（与后续 API 调用重叠执行，减少总等待时间）
  const ipFetchP = Promise.all([
    fetchExitIp('-x http://127.0.0.1:7890'),
    fetchExitIp("--noproxy '*'", 'http://ip.3322.net'),
  ]);

  // 并发拉取所有需要的 API
  const [ver, cfg, groups, conns] = await Promise.all([
    apiGet('/version'),
    apiGet('/configs').catch(() => ({})),
    apiGet('/proxies').catch(() => ({})),
    apiGet('/connections').catch(() => ({})),
  ]);

  // 版本 + 工具版本
  console.log(c.green('● 运行中') + `  mihomo: ${ver.version || '?'}   ctl: v${VERSION}   ${autostartStr}`);

  // PID & 端口
  const pid = (P.getPid() || '').split(/\s+/)[0];
  console.log(`  PID: ${pid || '?'}   端口: ${P.port7890Ok() ? c.green('7890 ✓') : c.red('7890 ✗')}  管理: 9090`);

  // 模式 & 日志 & DNS & 代理
  const logLevel = cfg['log-level'] || '?';
  const logStr   = logLevel === 'silent' ? c.dim('日志: 关闭') : c.yellow(`日志: ${logLevel}`);
  const dnsStr   = isDnsManagedByMihomo() ? c.green('DNS: 已接管') : c.dim('DNS: 系统默认');
  const proxyStr = P.isSystemProxyActive() ? c.green('代理: 已接管') : c.dim('代理: 系统默认');
  // TUN 状态：优先 API（运行中进程的真实状态），fallback 读 yaml（进程重建中时）
  let tunEnabled = cfg.tun?.enable === true;
  if (!tunEnabled) {
    try {
      const rawYaml = fs.readFileSync(CONFIG, 'utf8');
      const ti = rawYaml.indexOf('\ntun:\n');
      if (ti >= 0) tunEnabled = /\n\s+enable:\s*true/.test(rawYaml.slice(ti, ti + 300));
    } catch {}
  }
  const tunStr = tunEnabled ? c.green('TUN: 已接管') : c.dim('TUN: 未开启');
  console.log(`  模式: ${c.cyan(cfg.mode || '?')}   ${logStr}   ${dnsStr}   ${proxyStr}   ${tunStr}`);

  // 当前出口节点
  const main = groups?.proxies?.['\u{1F30D} 默认出口'];
  if (main?.now) console.log(`  默认出口: ${c.cyan(main.now)}`);
  const auto = groups?.proxies?.['\u{1F680} 自动选择'];
  if (auto?.now) console.log(`  自动选择: ${c.cyan(auto.now)}`);

  // 连接数 & 累计流量
  const connCount = (conns.connections || []).length;
  const { downloadTotal = 0, uploadTotal = 0 } = conns;
  const fmtB = b => b > 1e9 ? `${(b/1e9).toFixed(2)}GB` : b > 1e6 ? `${(b/1e6).toFixed(1)}MB` : b > 1e3 ? `${(b/1e3).toFixed(0)}KB` : `${b}B`;
  console.log(`  连接数: ${c.cyan(connCount)}   流量: \u2193${c.cyan(fmtB(downloadTotal))} \u2191${c.yellow(fmtB(uploadTotal))}`);

  // 出口 IP（代理 vs 直连）——此时并发检测通常已完成，基本无额外等待
  const [proxyIp, directIp] = await ipFetchP;
  if (proxyIp || directIp) {
    const same = proxyIp && directIp && proxyIp === directIp;
    if (same) {
      console.log(`  出口IP: ${c.cyan(proxyIp)}  ${c.dim('(代理=直连，代理可能未生效)')}`);
    } else {
      const pStr = proxyIp  ? c.cyan(proxyIp)  : c.dim('超时');
      const dStr = directIp ? c.dim(directIp)  : c.dim('超时');
      console.log(`  出口IP: 代理 ${pStr}   直连 ${dStr}`);
    }
  }

  // Geo 文件新鲜度（GeoIP + GeoSite）—— 实际位于 CONFIG_DIR 根，文件名随 geodata-mode
  const geoFiles = getGeoFiles().map(g => ({ label: g.label, file: path.join(CONFIG_DIR, g.name) }));
  const geoParts = geoFiles.map(({ label, file }) => {
    if (!fs.existsSync(file)) return `${label}: ${c.red('未下载')}`;
    const days = Math.floor((Date.now() - fs.statSync(file).mtimeMs) / 86400000);
    const age  = days === 0 ? '今天' : `${days}天前`;
    return `${label}: ${days > 30 ? c.yellow(age + ' ⚠') : c.dim(age)}`;
  });
  console.log(`  ${geoParts.join('   ')}`);
  if (geoFiles.some(({ file }) => !fs.existsSync(file)))
    console.log(c.dim('    更新: mihomo-ctl geo update'));
}
