    adapter      = PLATFORM_ADAPTERS[bak.platform] || P;
    iface        = bak.iface || bak.primaryIface
      || (Array.isArray(bak.services) ? bak.services[0]?.iface : null) || iface;
    dnsToRestore = (!bak.iface && Array.isArray(bak.services))
      ? (bak.services.find(s => s.iface === iface) || bak.services[0])?.dnsToRestore || null
      : bak.dnsToRestore || null;
  } catch {}
  console.log(c.bold(`\n── 关闭 DNS 接管 (接口: ${iface}) ────────────────`));
  try {
    const desc = await adapter.restoreAll(iface, dnsToRestore);
    try { fs.unlinkSync(DNS_BACKUP_FILE); } catch {}
    if (!keepAutostart) try { fs.unlinkSync(DNS_AUTOSTART_FILE); } catch {}
    console.log(c.green(`✓ DNS 已恢复为 ${desc}`));
  } catch (e) {
    console.log(c.red(`✗ 失败: ${e.message}`));
    adapter.adminHint?.();
  }
}

