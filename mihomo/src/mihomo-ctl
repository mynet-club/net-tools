  mihomo-ctl tun-on           开启 TUN 模式（接管所有 TCP/UDP，Telegram 等不走系统代理的 App 也能路由）
                              macOS/Linux: sudo 运行 Mihomo（auto-route 需 root 权限）
                              Windows: 需管理员权限 + WinTun 驱动（随 Mihomo Windows 版内置）
  mihomo-ctl tun-off          关闭 TUN 模式（恢复系统代理模式）

${c.cyan('终端临时代理（所有平台）')}
  export https_proxy=http://127.0.0.1:7890 http_proxy=http://127.0.0.1:7890
  unset https_proxy http_proxy

${c.cyan('配置文件')}
  ~/.config/mihomo/config.yaml
  ~/.config/mihomo/            geoip.metadb / geosite.dat（MMDB 模式，文件名随 geodata-mode）
  ~/.config/mihomo/logs/        mihomo.log / geo-update.log
  ${PLIST}
`);
}

// ─── 命令：tray（xbar / SwiftBar 菜单栏插件输出）─────────────────
// 插件脚本只需 exec 本命令；首行为菜单栏标题，--- 之后为下拉菜单。
// 菜单项用 xbar/SwiftBar 通用语法：text | bash=<self> param1=<cmd> terminal=false refresh=true
async function cmdTray(sub) {
  if (sub === 'install') { await cmdTrayInstall(); return; }

  let SELF;
  try { SELF = fs.realpathSync(process.argv[1]); } catch { SELF = process.argv[1]; }
  // 通过 /bin/bash -c 包一层并显式补 PATH：macOS 菜单栏 App（xbar/SwiftBar）
  // 拿到的 PATH 很精简，直接 exec node 脚本会因为找不到 node 而失败。
  const act = (label, ...params) => {
    const cmd = `export PATH=/opt/homebrew/bin:/usr/local/bin:$PATH; ${SELF} ${params.join(' ')}`;
    return `${label} | bash=/bin/bash param1=-c param2="${cmd}" terminal=false refresh=true`;
  };
  const sep = '---';

  const running = await isRunning();
  if (!running) {
    console.log('⚪️ Mihomo');
    console.log(sep);
    console.log('状态: 未运行 | color=gray');
    console.log(act('▶︎ 启动', 'start'));
    console.log(sep);
    console.log(act('🔄 刷新', 'tray'));
    return;
  }

  const [ver, cfg, groups] = await Promise.all([
    apiGet('/version').catch(() => ({})),
    apiGet('/configs').catch(() => ({})),
    apiGet('/proxies').catch(() => ({})),
  ]);
  const node = groups?.proxies?.['\u{1F30D} 默认出口']?.now
            || groups?.proxies?.['\u{1F680} 自动选择']?.now || '?';
  const proxyOn = P.isSystemProxyActive();
  const tunOn   = cfg.tun?.enable === true;

  // 菜单栏标题：绿点 + 当前节点（截断）
  const shortNode = node.length > 16 ? node.slice(0, 15) + '…' : node;
  console.log(`🟢 ${shortNode}`);
  console.log(sep);
  console.log(`Mihomo ${ver.version || ''} 运行中 | color=green`);
  console.log(`节点: ${node}`);
  console.log(`模式: ${cfg.mode || '?'}   系统代理: ${proxyOn ? '已接管' : '关闭'}   TUN: ${tunOn ? '开启' : '关闭'}`);
  console.log(sep);
  console.log(act('⏹ 停止', 'stop'));
  console.log(act('🔁 重启', 'restart'));
  console.log(act('♻︎ 重载配置', 'reload'));
  console.log(sep);
  if (proxyOn) console.log(act('🚫 关闭系统代理', 'proxy-off'));
  else         console.log(act('✅ 接管系统代理', 'proxy-on'));
  if (tunOn)   console.log(act('🚫 关闭 TUN', 'tun-off'));
  else         console.log(act('🌐 开启 TUN', 'tun-on'));
  console.log(sep);
  console.log(act('🖥 打开面板', 'ui', 'open'));
  console.log(act('🔄 刷新', 'tray'));
}

// 生成菜单栏插件脚本内容（xbar / SwiftBar 通用），内联生成无需任何源文件。
function trayPluginScript(selfPath) {
  return [
    '#!/usr/bin/env bash',
    '# Mihomo 菜单栏插件（xbar / SwiftBar 通用）',
    '# <xbar.title>Mihomo Status</xbar.title>',
    '# <xbar.version>v1.0</xbar.version>',
    '# <xbar.author>net-tools</xbar.author>',
    '# <xbar.desc>菜单栏显示 Mihomo 状态与快捷开关，由 mihomo-ctl tray 渲染。</xbar.desc>',
    '# <swiftbar.hideRunInTerminal>true</swiftbar.hideRunInTerminal>',
    '# <swiftbar.hideLastUpdated>true</swiftbar.hideLastUpdated>',
    '',
    '# 菜单栏 App 的 PATH 很精简，显式补上 node 常见位置',
    'export PATH="/opt/homebrew/bin:/usr/local/bin:$HOME/.bun/bin:$PATH"',
    '',
    `CTL="${selfPath}"`,
    '[ -x "$CTL" ] || CTL="$(command -v mihomo-ctl 2>/dev/null)"',
    '[ -z "$CTL" ] && [ -x /usr/local/bin/mihomo-ctl ] && CTL=/usr/local/bin/mihomo-ctl',
    '[ -z "$CTL" ] && [ -x /opt/homebrew/bin/mihomo-ctl ] && CTL=/opt/homebrew/bin/mihomo-ctl',
    'if [ -z "$CTL" ]; then echo "⚠️ Mihomo"; echo "---"; echo "未找到 mihomo-ctl | color=red"; exit 0; fi',
    'exec "$CTL" tray',
    '',
  ].join('\n');
}

// 安装菜单栏插件（仅 macOS）：内联生成插件 → 写入 xbar/SwiftBar 插件目录；
// 若两者都没装，则直接从 GitHub 下载 SwiftBar（zip/dmg）安装（仅 curl，无 brew 依赖）。
async function cmdTrayInstall() {
  if (P.name !== 'macos') {
    console.log(c.yellow('  菜单栏插件仅支持 macOS（依赖 xbar / SwiftBar）'));
    return;
  }
  const HOME = process.env.HOME || '';
  let SELF;
  try { SELF = fs.realpathSync(process.argv[1]); } catch { SELF = process.argv[1]; }
  const pluginText = trayPluginScript(SELF);

  console.log(c.bold('\n── 安装菜单栏插件 ────────────────────────────'));

  // 规范副本：始终在 ~/.config/mihomo/ 留一份，方便手动安装/排查
  fs.mkdirSync(CONFIG_DIR, { recursive: true });
  const canonical = path.join(CONFIG_DIR, 'mihomo.5s.sh');
  fs.writeFileSync(canonical, pluginText);
  fs.chmodSync(canonical, 0o755);

  const xbarAppDir  = path.join(HOME, 'Library/Application Support/xbar');
  const swiftAppDir = path.join(HOME, 'Library/Application Support/SwiftBar');
  const xbarPlugins  = path.join(xbarAppDir, 'plugins');
  const swiftPlugins = path.join(swiftAppDir, 'Plugins');

  const writePlugin = (dir) => {
    fs.mkdirSync(dir, { recursive: true });
    const dst = path.join(dir, 'mihomo.5s.sh');
    fs.writeFileSync(dst, pluginText);
    fs.chmodSync(dst, 0o755);
    return dst;
  };

  let installed = 0;
  if (fs.existsSync(xbarAppDir)) {
    console.log(c.green(`  ✓ xbar: ${writePlugin(xbarPlugins)}`));
    run('open -g "xbar://app.xbarapp.com/refreshAllPlugins" 2>/dev/null');
    installed++;
  }
  if (fs.existsSync(swiftAppDir)) {
    console.log(c.green(`  ✓ SwiftBar: ${writePlugin(swiftPlugins)}`));
    run(`defaults write com.ameba.SwiftBar PluginDirectory "${swiftPlugins}" 2>/dev/null`);
    run('open -g "swiftbar://refreshallplugins" 2>/dev/null');
    installed++;
  }

  if (installed > 0) {
    console.log(c.dim('\n  插件已写入，菜单栏稍候即会出现 Mihomo 图标'));
    return;
  }

  // 未检测到任何宿主 App —— 直接从 GitHub 下载安装 SwiftBar（仅用 curl，无 brew 依赖）
  console.log(c.yellow('  未检测到 xbar / SwiftBar，开始从 GitHub 安装 SwiftBar...'));
  const ok = await downloadInstallSwiftBar();
  if (!ok) {
    console.log(c.dim(`\n  插件脚本已就绪: ${canonical}`));
    console.log(c.dim('  也可手动安装 SwiftBar(https://swiftbar.app) 或 xbar(https://xbarapp.com) 后重试'));
    return;
  }
  const dst = writePlugin(swiftPlugins);
  // 预设插件目录，让 SwiftBar 首启时跳过选择向导
  run(`defaults write com.ameba.SwiftBar PluginDirectory "${swiftPlugins}" 2>/dev/null`);
  console.log(c.green(`\n  ✓ SwiftBar 已安装，插件: ${dst}`));
  run('open -a SwiftBar 2>/dev/null');
  console.log(c.dim('  SwiftBar 已启动。若弹窗要求选择插件目录，请选择：'));
  console.log(c.dim(`    ${swiftPlugins}`));
}

// 直接从 GitHub Releases 下载 SwiftBar 并安装到 /Applications（仅依赖 curl + unzip/hdiutil）
async function downloadInstallSwiftBar() {
  // 1) 查询最新 release，优先 .zip（官方现在用 zip 分发），其次 .dmg
  const apiUrl = 'https://api.github.com/repos/swiftbar/SwiftBar/releases/latest';
  const meta = run(`curl -fsSL -4 --max-time 30 ${resolveProxyArg()} -H "Accept: application/vnd.github+json" "${apiUrl}" 2>/dev/null`);
  let asset = null;
  try {
    const json = JSON.parse(meta);
    const assets = json.assets || [];
    asset = assets.find(a => /\.zip$/i.test(a.name)) || assets.find(a => /\.dmg$/i.test(a.name));
  } catch {}
  if (!asset || !asset.browser_download_url) {
    console.log(c.red('  ✗ 无法获取 SwiftBar 下载地址（GitHub API 失败）'));
    return false;
  }
  const isZip = /\.zip$/i.test(asset.name);
  const dlUrl = asset.browser_download_url;

  // 2) 下载
  const file = path.join(TMP, `${path.basename(asset.name)}`);
  process.stdout.write(`  下载 ${asset.name}... `);
  run(`curl -fsSL -4 -L --max-time 180 ${resolveProxyArg()} -o "${file}" "${dlUrl}" 2>/dev/null`);
  if (!fs.existsSync(file) || fs.statSync(file).size < 500000) {
    console.log(c.red('✗ 下载失败或文件过小'));
    try { fs.unlinkSync(file); } catch {}
    return false;
  }
  console.log(c.green(`✓ ${(fs.statSync(file).size / 1024 / 1024).toFixed(1)} MB`));

  // 3) 解出 SwiftBar.app 并拷贝到 /Applications（失败回退 ~/Applications）
  const targets = ['/Applications', path.join(process.env.HOME || '', 'Applications')];
  const installApp = (srcApp) => {
    const appName = path.basename(srcApp);
    for (const tdir of targets) {
      try {
        fs.mkdirSync(tdir, { recursive: true });
        const dstApp = path.join(tdir, appName);
        fs.rmSync(dstApp, { recursive: true, force: true });
        run(`cp -R "${srcApp}" "${dstApp}"`);
        if (fs.existsSync(dstApp)) return tdir;
      } catch {}
    }
    return '';
  };

  let appliedDir = '';
  if (isZip) {
    const tmpDir = path.join(TMP, `swiftbar-zip-${Date.now()}`);
    fs.mkdirSync(tmpDir, { recursive: true });
    try {
      process.stdout.write('  解压并安装... ');
      run(`unzip -oq "${file}" -d "${tmpDir}"`);
      const appName = walkFindApp(tmpDir);
      if (!appName) throw new Error('zip 内未找到 .app');
      appliedDir = installApp(appName);
    } catch (e) {
      console.log(c.red(`✗ ${e.message}`));
    } finally {
      try { fs.rmSync(tmpDir, { recursive: true, force: true }); } catch {}
      try { fs.unlinkSync(file); } catch {}
    }
  } else {
    const mnt = path.join(TMP, `swiftbar-mnt-${Date.now()}`);
    fs.mkdirSync(mnt, { recursive: true });
    try {
      process.stdout.write('  挂载并安装... ');
      run(`hdiutil attach "${file}" -nobrowse -quiet -mountpoint "${mnt}"`);
      const appName = fs.readdirSync(mnt).find(n => /\.app$/i.test(n));
      if (!appName) throw new Error('dmg 内未找到 .app');
      appliedDir = installApp(path.join(mnt, appName));
    } catch (e) {
      console.log(c.red(`✗ ${e.message}`));
    } finally {
      run(`hdiutil detach "${mnt}" -quiet 2>/dev/null`);
      try { fs.rmSync(mnt, { recursive: true, force: true }); } catch {}
      try { fs.unlinkSync(file); } catch {}
    }
  }

  if (!appliedDir) {
    console.log(c.red('✗ 安装失败（无法写入 /Applications）'));
    return false;
  }
  // 移除下载隔离属性，避免首次打开被 Gatekeeper 拦截
  run(`xattr -dr com.apple.quarantine "${path.join(appliedDir, 'SwiftBar.app')}" 2>/dev/null`);
  console.log(c.green(`✓ 已安装到 ${appliedDir}/SwiftBar.app`));
  return true;
}

// 在目录树中查找第一个 .app（zip 解压后 SwiftBar.app 可能不在顶层）
function walkFindApp(dir) {
  for (const ent of fs.readdirSync(dir)) {
    const full = path.join(dir, ent);
    if (/\.app$/i.test(ent)) return full;
    try {
      if (fs.statSync(full).isDirectory()) {
        const found = walkFindApp(full);
        if (found) return found;
      }
    } catch {}
  }
  return '';
}

// ─── 入口 ──────────────────────────────────────────────────────
const [,, cmd, ...args] = process.argv;
(async () => {
  switch (cmd) {
    case 'status':  await cmdStatus();  break;
    case 'proxies': await cmdProxies(); break;
    case 'test':    await cmdTest();    break;
    case 'select':  await cmdSelect(args[0], args[1]); break;
    case 'start':      await cmdStart(args);   break;
    case 'stop':       await cmdStop();      break;
    case 'restart':    await cmdRestart();   break;
    case 'reload':     await cmdReload();    break;
    case 'conflicts':
    case 'conflict':   await cmdConflicts(args); break;
    case 'upgrade':
      if (args[0] === 'mihomo') await cmdUpgradeMihomo();
      else await cmdUpgrade();
      break;
    case 'self-upgrade': await cmdUpgrade(); break;  // 向后兼容别名
    case 'check':      cmdCheck();           break;
    case 'mode':       await cmdMode(args[0]); break;
    case 'geo':        await cmdGeo(args[0]); break;
    case 'traffic':    await cmdTraffic();   break;
    case 'connections': await cmdConnections(args[0]); break;
    case 'backup':     cmdBackup();          break;
    case 'restore':    cmdRestore(args[0]);  break;
    case 'ui':         await cmdUi(args[0]); break;
    case 'autostart':  cmdAutostart(args[0]); break;
    case 'log':        cmdLog();             break;
    case 'log-on':     await cmdLogOn();     break;
    case 'log-off':    await cmdLogOff();    break;
    case 'proxy-on':   await cmdProxyOn();   break;
    case 'proxy-off':  await cmdProxyOff();  break;
    case 'proxy-env':  cmdProxyEnv();        break;
    case 'dns-on':     await cmdDnsOn();     break;
    case 'dns-off':    await cmdDnsOff();    break;
    case 'dns':        await cmdDnsStatus(); break;
    case 'tun-on':     await cmdTunOn();     break;
    case 'tun-off':    await cmdTunOff();    break;
    case 'tray':       await cmdTray(args[0]); break;
    case 'version': case '-v': case '--version':
      console.log(`mihomo-ctl v${VERSION}`); break;
    case 'help': case '--help': case '-h': cmdHelp(); break;
    default:
      await cmdStatus();
      console.log(c.dim('\n运行 mihomo-ctl help 查看所有命令'));
  }
})();
