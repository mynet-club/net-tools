// ─── Clash/Mihomo 家族进程互斥 ────────────────────────────────
// 背景：ClashX Meta / Clash Verge / Mihomo Party 等 GUI 都内置自己的 mihomo
// 内核，会抢占 7890/9090/53 端口。更隐蔽的是：第三方 mihomo 占用 9090 后，
// isRunning() 仅凭 API 返回的 version 字段会误判为"本工具已在运行"，从而引发
// 各种诡异问题。启动前先做互斥，结束这些冲突进程，确保端口干净。
const CONFLICT_KEYWORDS = [
  'clashx',            // ClashX / ClashX Pro / ClashX Meta
  'clash verge', 'clash-verge', 'verge-mihomo', 'clash-nyanpasu', 'nyanpasu',
  'clash-meta', 'clash.meta', 'clashmeta',
  'clash for windows',
  'mihomo party', 'mihomo-party',
  'flclash', 'stash.app', 'clashn',
];

// 本工具自己的 mihomo 内核：/usr/local/bin/mihomo -d ~/.config/mihomo
function isOwnMihomoCore(cmd) {
  return cmd.includes(BIN) && cmd.includes(CONFIG_DIR);
}

// 结束指定 PID（先普通信号，hard=true 时强杀）
function killConflictPid(pid, hard) {
  if (IS_WIN) { run(`taskkill /PID ${pid} ${hard ? '/F' : ''} /T 2>NUL`); return; }
  const sig = hard ? '-9' : '';
  run(`sudo kill ${sig} ${pid} 2>/dev/null || kill ${sig} ${pid} 2>/dev/null || true`);
}

// Windows: 用 tasklist 检测已知 GUI/内核（无法区分自带 mihomo.exe，故只盯 GUI）
function detectConflictsWin() {
  const out = run('tasklist /FO CSV /NH 2>NUL');
  if (!out) return [];
  const names = ['clashx', 'clash-verge', 'verge', 'nyanpasu', 'flclash', 'stash', 'clash.exe', 'clashn'];
  const results = [];
  for (const line of out.split('\n')) {
    const m = line.match(/^"([^"]+)","(\d+)"/);
    if (!m) continue;
    const name = m[1], pid = m[2];
    if (pid === String(process.pid)) continue;
    if (names.some(k => name.toLowerCase().includes(k))) results.push({ pid, cmd: name });
  }
  return results;
}

// 返回与本工具冲突的 Clash/Mihomo 家族进程 [{pid, cmd}]
function detectConflicts() {
  if (IS_WIN) return detectConflictsWin();
  const out = run('ps -axww -o pid=,command= 2>/dev/null');
  if (!out) return [];
  const selfPid = String(process.pid);
  const ppid    = String(process.ppid || '');
  const results = [];
  for (const line of out.split('\n')) {
    const m = line.match(/^\s*(\d+)\s+(.+)$/);
    if (!m) continue;
    const pid = m[1];
    const cmd = m[2].trim();
    if (pid === selfPid || pid === ppid) continue;
    if (cmd.includes('mihomo-ctl')) continue;   // 本工具脚本自身
    if (cmd.includes('ps -axww'))   continue;   // 本次 ps 调用自身
    if (isOwnMihomoCore(cmd))       continue;   // 本工具的 mihomo 内核
    const low = cmd.toLowerCase();
    let hit = CONFLICT_KEYWORDS.some(k => low.includes(k));
    // 第三方 mihomo / clash 内核（非本工具内核，上面已排除）
    if (!hit && /(^|\/|\s)(mihomo|clash)(\s|$|-d)/.test(low)) hit = true;
    if (hit) results.push({ pid, cmd: cmd.length > 110 ? cmd.slice(0, 107) + '...' : cmd });
  }
  return results;
}

// 简单的 [Y/n] 确认提示
function confirmYesNo(question) {
  return new Promise(resolve => {
    const readline = require('readline');
    const rl = readline.createInterface({ input: process.stdin, output: process.stdout });
    rl.question(c.yellow(question), ans => {
      rl.close();
      const a = (ans || '').trim().toLowerCase();
      resolve(a === '' || a === 'y' || a === 'yes');
    });
  });
}

// 启动前互斥：检测并结束冲突进程。返回 true 表示可以继续启动
async function guardAgainstConflicts({ force = false } = {}) {
  const conflicts = detectConflicts();
  if (conflicts.length === 0) return true;

  console.log(c.yellow(`\n⚠ 检测到 ${conflicts.length} 个可能冲突的 Clash/Mihomo 进程：`));
  conflicts.forEach(p => console.log(`  ${c.red('PID ' + p.pid)}  ${c.dim(p.cmd)}`));
  console.log(c.dim('  它们可能抢占 7890 / 9090 / 53 端口，导致 Mihomo 启动异常或行为诡异。'));

  const interactive = process.stdin.isTTY && process.stdout.isTTY;
  let doKill = force;
  if (!doKill) {
    if (interactive) {
      doKill = await confirmYesNo('  是否结束这些进程以释放端口？ [Y/n] ');
    } else {
      doKill = true; // 非交互（如开机自启）默认结束冲突进程，保证启动可靠
      console.log(c.dim('  非交互模式：自动结束冲突进程'));
    }
  }
  if (!doKill) {
    console.log(c.yellow('  已取消。请手动退出上述程序后重试，或: mihomo-ctl start --force'));
    return false;
  }

  conflicts.forEach(p => killConflictPid(p.pid, false));
  await new Promise(r => setTimeout(r, 800));
  let still = detectConflicts();
  if (still.length) {
    still.forEach(p => killConflictPid(p.pid, true)); // 残留进程强杀
    await new Promise(r => setTimeout(r, 400));
    still = detectConflicts();
  }
  if (still.length) {
    console.log(c.yellow(`  ⚠ 仍有 ${still.length} 个进程未结束，可能需手动退出 GUI 应用：`));
    still.forEach(p => console.log(c.dim(`    PID ${p.pid}  ${p.cmd}`)));
    return false;
  }
  console.log(c.green('  ✓ 冲突进程已结束，端口已释放'));
  return true;
}

// ─── 命令：conflicts（查看/结束冲突进程）──────────────────────
async function cmdConflicts(args = []) {
  const force = args.some(a => ['--force', '-f', '--kill', '-y', '--yes'].includes(a));
  console.log(c.bold('\n── Clash/Mihomo 进程互斥检查 ─────────────────'));
  const list = detectConflicts();
  if (!list.length) { console.log(c.green('✓ 未检测到冲突进程')); return; }
  if (force) { await guardAgainstConflicts({ force: true }); return; }
  console.log(c.yellow(`检测到 ${list.length} 个可能冲突的进程：`));
  list.forEach(p => console.log(`  ${c.red('PID ' + p.pid)}  ${c.dim(p.cmd)}`));
  console.log(c.dim('\n  结束这些进程: mihomo-ctl conflicts --force'));
  console.log(c.dim('  或启动时自动处理: mihomo-ctl start'));
}

// ─── 命令：start / stop / restart ─────────────────────────────
async function cmdStart(args = []) {
  const force = args.some(a => ['--force', '-f', '--yes', '-y'].includes(a));
  // 互斥：先结束抢占端口的 Clash/Mihomo 家族进程（ClashX/Verge 等），
  // 否则第三方内核占用 9090 会让 isRunning() 误判为"已运行"。
  if (!(await guardAgainstConflicts({ force }))) return;

  // 如果（本工具的）Mihomo 已运行则确保代理和 DNS 状态正确
  if (await isRunning()) {
    console.log(c.yellow('⚠ Mihomo 已在运行，自动确认系统代理状态...'));
    await cmdProxyOn();
    if (fs.existsSync(DNS_AUTOSTART_FILE)) await cmdDnsOn();
    return;
  }
  // 确保日志目录存在
  const logsDir = path.dirname(LOG);
  if (!fs.existsSync(logsDir)) fs.mkdirSync(logsDir, { recursive: true });

  console.log('启动 Mihomo...');
  P.startProcess();
  let started = false;
  for (let i = 0; i < 8; i++) {
    await new Promise(r => setTimeout(r, 500));
    if (await isRunning()) { started = true; break; }
  }
  if (started) {
    console.log(c.green('✓ 已启动'));
    await cmdProxyOn();
    if (fs.existsSync(DNS_AUTOSTART_FILE)) await cmdDnsOn();
  } else {
    console.log(c.red('✗ 启动失败'));
    diagnoseStartFailure(); // 保持兼容，后续可传递错误对象
  }
}

function isDnsManagedByMihomo() {
  if (!fs.existsSync(DNS_BACKUP_FILE)) return false;
  try {
    const bak   = JSON.parse(fs.readFileSync(DNS_BACKUP_FILE, 'utf8'));
    const iface = bak.iface || bak.primaryIface
      || (Array.isArray(bak.services) ? bak.services[0]?.iface : null);
    if (!iface) return false;
    const adapter = PLATFORM_ADAPTERS[bak.platform] || P;
    return adapter.isDnsActive(iface);
  } catch { return false; }
}

async function shutdownProcess(label) {
  process.stdout.write(label + ' ');
  P.stopProcess();
  for (let i = 0; i < 6; i++) {
    await new Promise(r => setTimeout(r, 500));
    if (!(await isRunning())) return true;
  }
  P.forceKill();
  await new Promise(r => setTimeout(r, 500));
  return !(await isRunning());
}

function getTunEnableFromConfig() {
  if (!fs.existsSync(CONFIG)) return null;
  try {
    const cfgText = fs.readFileSync(CONFIG, 'utf8');
    const tunIdx  = cfgText.indexOf('\ntun:\n');
    if (tunIdx === -1) return null;
    const enableIdx = cfgText.indexOf('\n  enable:', tunIdx);
    if (enableIdx === -1) return null;
    const lineEnd = cfgText.indexOf('\n', enableIdx + 1);
    const line    = lineEnd === -1 ? cfgText.slice(enableIdx) : cfgText.slice(enableIdx, lineEnd);
    if (/enable:\s*true/.test(line)) return true;
    if (/enable:\s*false/.test(line)) return false;
    return null;
  } catch {
    return null;
  }
}

function recordStopPreferences() {
  const pref = {
    savedAt: new Date().toISOString(),
    platform: P.name,
    proxyManaged: P.supportsProxy ? P.isSystemProxyActive() : false,
    dnsManaged: P.supportsDns ? isDnsManagedByMihomo() : false,
    dnsAutostart: fs.existsSync(DNS_AUTOSTART_FILE),
    tunEnableInConfig: getTunEnableFromConfig(),
    tunStateFile: fs.existsSync(TUN_STATE_FILE),
  };
  fs.mkdirSync(CONFIG_DIR, { recursive: true });
  fs.writeFileSync(STOP_PREF_FILE, JSON.stringify(pref, null, 2));
  return pref;
}

function forceTunOffInConfig() {
  if (!fs.existsSync(CONFIG)) return false;
  try {
    const cfgText = fs.readFileSync(CONFIG, 'utf8');
    const newCfg  = setTunEnable(cfgText, 'false');
    if (newCfg && newCfg !== cfgText) {
      fs.writeFileSync(CONFIG, newCfg);
      return true;
    }
    return false;
  } catch {
    return false;
  }
}

async function cmdStop() {
  const pref = recordStopPreferences();
  console.log(c.dim(`  已记录停机前默认设置: ${STOP_PREF_FILE}`));

  if (P.supportsProxy) {
    process.stdout.write('  执行 proxy-off... ');
    await cmdProxyOff();
  }
  if (P.supportsDns) {
    console.log(c.yellow('  执行 dns-off...'));
    await cmdDnsOff({ keepAutostart: true });
  }

  const tunChanged = forceTunOffInConfig();
  try { fs.unlinkSync(TUN_STATE_FILE); } catch {}
  if (tunChanged) console.log(c.green('  ✓ 已写入 tun-off（config.tun.enable=false）'));
  else console.log(c.dim('  ✓ tun-off 已确认（配置无需变更）'));

  const stopped = await shutdownProcess('停止 Mihomo...');
  if (stopped) {
    const notes = [
      P.supportsProxy && '系统代理已关闭',
      P.supportsDns && 'DNS 已恢复',
      'TUN 已关闭',
      pref.dnsAutostart && '已保留 DNS 自动恢复标记',
    ].filter(Boolean);
    console.log(c.green('✓ 已停止' + (notes.length ? '，' + notes.join('，') : '')));
  } else {
    console.log(c.yellow(`进程仍在，手动: ${P.killHint()}`));
  }
}

async function cmdRestart() {
  const dnsManaged   = isDnsManagedByMihomo();
  const proxyManaged = P.isSystemProxyActive();
  if (proxyManaged) {
    process.stdout.write('  系统代理接管中，先关闭代理... ');
    await cmdProxyOff();
  }
  if (dnsManaged) {
    console.log(c.yellow('  DNS 接管中，先恢复 DNS...'));
    await cmdDnsOff({ keepAutostart: true });
  }
  await shutdownProcess('停止旧进程...');
  console.log(c.dim('done'));

  // 互斥：停掉本工具旧进程后，再清理可能抢占端口的第三方 Clash/Mihomo 进程
  await guardAgainstConflicts({ force: true });

  process.stdout.write('启动新进程... ');
  P.startProcess();
  let started = false;
  for (let i = 0; i < 8; i++) {
    await new Promise(r => setTimeout(r, 500));
    if (await isRunning()) { started = true; break; }
  }

  if (started) {
    console.log(c.green('✓ 已重启'));
    await cmdProxyOn();
    if (dnsManaged) await cmdDnsOn();
  } else {
    console.log(c.red('✗ 重启失败'));
    diagnoseStartFailure(); // 保持兼容，后续可传递错误对象
  }
}

// ─── 命令：log ─────────────────────────────────────────────────
function cmdLog() {
  if (!fs.existsSync(LOG) || fs.statSync(LOG).size === 0) {
    console.log(c.dim('  日志为空（当前日志级别: silent）'));
    console.log(c.dim('  开启日志: mihomo-ctl log-on'));
    return;
  }
  console.log(c.dim(`日志文件: ${LOG}\n`));
  try {
    const lines = execSync(`tail -50 "${LOG}"`, { encoding: 'utf8' });
    const colored = lines.split('\n').map(l => {
      if (l.includes('ERR') || l.includes('error')) return c.red(l);
      if (l.includes('WARN'))  return c.yellow(l);
      if (l.includes('INFO'))  return c.dim(l);
      return l;
    }).join('\n');
    console.log(colored);
  } catch { console.log(c.red('读取日志失败')); }
  console.log(c.dim(`\n实时查看: tail -f ${LOG}`));
}

// ─── 命令：ui ──────────────────────────────────────────────────
// 返回内置面板 HTML：打包后由 release.js 注入的 _BUNDLED_UI_（base64）提供；
// 源码模式下回退读取仓库 ../ui/index.html。这样安装后无需任何源文件即可工作。
function getBuiltinUiHtml() {
  if (typeof _BUNDLED_UI_ !== 'undefined' && _BUNDLED_UI_) {
    return Buffer.from(_BUNDLED_UI_, 'base64').toString('utf8');
  }
  try {
    const scriptDir = path.dirname(fs.realpathSync(process.argv[1]));
    const srcUi = path.join(scriptDir, '..', 'ui', 'index.html');
    if (fs.existsSync(srcUi)) return fs.readFileSync(srcUi, 'utf8');
  } catch {}
  return '';
}

// 写入 config.yaml 的 external-ui；lock=true 时把 external-ui-url 置空，
// 阻止内核启动时下载默认面板覆盖我们当前的面板。
function writeExternalUiConfig(dstUi) {
  if (!fs.existsSync(CONFIG)) return;
  let yaml = fs.readFileSync(CONFIG, 'utf8');
  if (/^external-ui:/m.test(yaml)) {
    yaml = yaml.replace(/^external-ui:.*$/m, `external-ui: ${dstUi}`);
  } else if (/^external-controller:/m.test(yaml)) {
    yaml = yaml.replace(/(external-controller:[^\n]*)/, `$1\nexternal-ui: ${dstUi}`);
  } else {
    yaml += `\nexternal-ui: ${dstUi}\n`;
  }
  if (/^external-ui-url:/m.test(yaml)) {
    yaml = yaml.replace(/^external-ui-url:.*$/m, `external-ui-url: ''`);
  } else {
    yaml = yaml.replace(/^external-ui:.*$/m, m => `${m}\nexternal-ui-url: ''`);
  }
  fs.writeFileSync(CONFIG, yaml);
}

// 探测当前 UI_DIR 里安装的是哪种面板（读 <title>）
function detectActiveUi() {
  const idx = path.join(UI_DIR, 'index.html');
  if (!fs.existsSync(idx)) return { kind: 'none' };
  let title = '';
  try {
    const m = fs.readFileSync(idx, 'utf8').match(/<title>([^<]*)<\/title>/i);
    title = m ? m[1].trim() : '';
  } catch {}
  const mtime = fs.statSync(idx).mtimeMs;
  if (/metacube/i.test(title)) return { kind: 'metacubexd', title, mtime };
  if (/mihomo/i.test(title))   return { kind: 'local', title, mtime };
  return { kind: 'unknown', title, mtime };
}

// 安装内置精简面板（本项目自带的单文件页面）
function installLocalUi() {
  const html = getBuiltinUiHtml();
  if (!html) {
    console.log(c.red('✗ 内置面板不可用（请从源码目录运行，或重装 mihomo-ctl）'));
    return false;
  }
  if (fs.existsSync(UI_DIR)) {
    for (const ent of fs.readdirSync(UI_DIR)) {
      try { fs.rmSync(path.join(UI_DIR, ent), { recursive: true, force: true }); } catch {}
    }
  }
  fs.mkdirSync(UI_DIR, { recursive: true });
  fs.writeFileSync(path.join(UI_DIR, 'index.html'), html);
  writeExternalUiConfig(UI_DIR);
  console.log(c.green('\n  ✓ 已切换到内置面板（Mihomo CTL）'));
  console.log(c.dim(`  路径: ${UI_DIR}/index.html`));
  console.log(c.dim("  已锁定 external-ui-url: '' （内核不会再下载覆盖）"));
  console.log(c.dim('\n  生效: mihomo-ctl reload    访问: http://127.0.0.1:9090/ui/'));
  return true;
}

// 直接下载 MetaCubeXD（官方功能完整面板）并安装到 UI_DIR
async function installMetaUi() {
  const url = 'https://github.com/MetaCubeX/metacubexd/archive/refs/heads/gh-pages.zip';
  console.log(c.bold('\n── 下载 MetaCubeXD 面板 ───────────────────────'));
  console.log(c.dim(`  来源: ${url}`));
  const tmpZip = path.join(TMP, `mcxd-${Date.now()}.zip`);
  const tmpDir = path.join(TMP, `mcxd-${Date.now()}`);
  process.stdout.write('  下载中... ');
  run(`curl -fsSL -4 -L --max-time 120 ${resolveProxyArg()} -o "${tmpZip}" "${url}" 2>/dev/null`);
  if (!fs.existsSync(tmpZip) || fs.statSync(tmpZip).size < 50000) {
    console.log(c.red('✗ 下载失败或文件过小，请检查网络/代理'));
    try { fs.unlinkSync(tmpZip); } catch {}
    return false;
  }
  console.log(c.green(`✓ ${(fs.statSync(tmpZip).size / 1024 / 1024).toFixed(1)} MB`));

  process.stdout.write('  解压中... ');
  fs.mkdirSync(tmpDir, { recursive: true });
  try { run(`unzip -oq "${tmpZip}" -d "${tmpDir}"`); }
  catch (e) { console.log(c.red(`✗ 解压失败: ${e.message}`)); return false; }

  // 找到含 index.html 的根目录（gh-pages.zip 解出 metacubexd-gh-pages/）
  let srcRoot = tmpDir;
  const top = fs.readdirSync(tmpDir);
  if (!top.includes('index.html') && top.length === 1) srcRoot = path.join(tmpDir, top[0]);
  if (!fs.existsSync(path.join(srcRoot, 'index.html'))) {
    console.log(c.red('✗ 压缩包结构异常，未找到 index.html'));
    try { fs.rmSync(tmpZip, { force: true }); fs.rmSync(tmpDir, { recursive: true, force: true }); } catch {}
    return false;
  }

  fs.rmSync(UI_DIR, { recursive: true, force: true });
  fs.mkdirSync(UI_DIR, { recursive: true });
  fs.cpSync(srcRoot, UI_DIR, { recursive: true });
  console.log(c.green('✓ 完成'));
  try { fs.rmSync(tmpZip, { force: true }); fs.rmSync(tmpDir, { recursive: true, force: true }); } catch {}

  writeExternalUiConfig(UI_DIR);
  console.log(c.green('\n  ✓ 已切换到 MetaCubeXD 面板'));
  console.log(c.dim(`  路径: ${UI_DIR}/`));
  console.log(c.dim('\n  生效: mihomo-ctl reload    访问: http://127.0.0.1:9090/ui/'));
  return true;
}

