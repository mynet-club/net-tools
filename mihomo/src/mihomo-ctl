// external-controller secret：从 config.yaml 读取，给所有 API 调用加 Authorization 头
// （用户给 9090 设了 secret 后，CLI 不加此头会被 401，所有命令失效）
let _secretCache;
function getSecret() {
  if (_secretCache !== undefined) return _secretCache;
  _secretCache = '';
  try {
    const m = fs.readFileSync(CONFIG, 'utf8').match(/^secret:\s*["']?([^"'#\s]+)["']?/m);
    if (m) _secretCache = m[1];
  } catch {}
  return _secretCache;
}
function authHeaders(extra) {
  const h = extra ? { ...extra } : {};
  const s = getSecret();
  if (s) h['Authorization'] = `Bearer ${s}`;
  return h;
}

function apiGet(path) {
  return new Promise((resolve, reject) => {
    const req = http.get(`${API}${path}`, { timeout: 3000, headers: authHeaders() }, res => {
      let data = '';
      res.on('data', d => data += d);
      res.on('end', () => {
        try { resolve(JSON.parse(data)); }
        catch { resolve(data); }
      });
    });
    req.on('error', reject);
    req.on('timeout', () => { req.destroy(); reject(new Error('timeout')); });
  });
}

function apiPut(path, body) {
  return new Promise((resolve, reject) => {
    const data = JSON.stringify(body);
    const opts = {
      hostname: '127.0.0.1', port: 9090, path, method: 'PUT',
      headers: authHeaders({ 'Content-Type': 'application/json', 'Content-Length': Buffer.byteLength(data) }),
      timeout: 3000,
    };
    const req = http.request(opts, res => {
      let d = '';
      res.on('data', c => d += c);
      res.on('end', () => resolve({ status: res.statusCode, body: d }));
    });
    req.on('error', reject);
    req.on('timeout', () => { req.destroy(); reject(new Error('timeout')); });
    req.write(data);
    req.end();
  });
}

function apiPatch(urlPath, body) {
  return new Promise((resolve, reject) => {
    const data = JSON.stringify(body);
    const req = http.request({
      hostname: '127.0.0.1', port: 9090, path: urlPath, method: 'PATCH',
      headers: authHeaders({ 'Content-Type': 'application/json', 'Content-Length': Buffer.byteLength(data) }),
      timeout: 3000,
    }, res => { res.resume(); resolve(res.statusCode); });
    req.on('error', reject);
    req.on('timeout', () => { req.destroy(); reject(new Error('timeout')); });
    req.write(data); req.end();
  });
}

function apiDelete(urlPath) {
  return new Promise((resolve, reject) => {
    const req = http.request({
      hostname: '127.0.0.1', port: 9090, path: urlPath, method: 'DELETE', timeout: 3000,
      headers: authHeaders(),
    }, res => { res.resume(); resolve(res.statusCode); });
    req.on('error', reject);
    req.on('timeout', () => { req.destroy(); reject(new Error('timeout')); });
    req.end();
  });
}

function run(cmd) {
  try { return execSync(cmd, { encoding: 'utf8', shell: IS_WIN ? 'cmd.exe' : '/bin/sh' }).trim(); }
  catch { return ''; }
}

// Windows 自动提权重运当前命令（UAC）
function winElevate(cmdName) {
  const exe    = process.execPath.replace(/\\/g, '\\\\');
  const script = process.argv[1].replace(/\\/g, '\\\\');
  try {
    execSync(
      `powershell -NoProfile -Command "Start-Process -Verb RunAs -FilePath '${exe}' -ArgumentList '${script} ${cmdName}' -Wait"`,
      { stdio: 'inherit' }
    );
  } catch {
    console.log(c.yellow('⚠ UAC 已取消或超时，请以管理员身份重试'));
  }
}

// 解析最佳下载代理：优先读系统代理，其次检测 Mihomo HTTP 代理 7890（TUN 模式）
function resolveProxyArg() {
  const arg = P.getCurlProxyArg();
  if (arg) return arg;
  // TUN 模式下系统代理为空，但 127.0.0.1:7890 可能在监听
  const _ns = IS_WIN ? run('netstat -ano 2>nul') : run('netstat -an 2>/dev/null');
  if (/127\.0\.0\.1[.:]7890/.test(_ns)) {
    return '-x "http://127.0.0.1:7890"';
  }
  return '';
}

// ─── 平台适配器注册表 ─────────────────────────────────────────
// 所有平台相关的原子操作按平台集中封装，命令函数调用 P.xxx()，无需 if/else

function detectPlatform() {
  if (IS_WIN) return 'windows';
  if (process.platform === 'darwin') return 'macos';
  if (fs.existsSync('/etc/alpine-release'))  return 'alpine';
  if (fs.existsSync('/etc/openwrt_release')) return 'openwrt';
  if (process.platform === 'linux')   return 'linux';
  if (process.platform === 'freebsd') return 'freebsd';
  return 'linux';
}

// 工厂：为 systemd / OpenRC / rc.d 等 Linux 系列生成基础适配器
function createServiceAdapter(name, stopCmd, startCmd) {
  return {
    name, supportsProxy: false, supportsDns: false,

    // ── 进程 ──────────────────────────────────────────────────
    stopProcess()  { run(stopCmd);  },
    startProcess() { run(startCmd); },
    forceKill()    { run(`sudo pkill -KILL -f 'mihomo -d' 2>/dev/null || pkill -KILL -f 'mihomo -d' 2>/dev/null || true`); },
    getPid()       { return run("pgrep -f 'mihomo -d'"); },
    killHint()     { return 'sudo kill $(pgrep -f "mihomo -d")'; },
    port7890Ok()   { return !!run('ss -tlnp 2>/dev/null | grep :7890 || lsof -i :7890 -sTCP:LISTEN -n 2>/dev/null | grep mihomo'); },
    hasGit()       { return !!run('which git 2>/dev/null'); },
    gitNull:         '2>/dev/null',
    extraOfflineStatus() {},

    // ── 开机自启 ──────────────────────────────────────────────
    isAutostartEnabled()  { return false; },
    enableAutostart()     { console.log(c.yellow('⚠ 请使用系统服务管理器配置自启')); },
    disableAutostart()    { console.log(c.yellow('⚠ 请使用系统服务管理器配置自启')); },

    // ── 系统代理 ──────────────────────────────────────────────
    getCurlProxyArg()       { return ''; },
    isSystemProxyActive()   { return false; },
    getActiveInterface()    { return null; },
    setSystemProxy()        { throw new Error('不支持'); },
    clearSystemProxy()      { throw new Error('不支持'); },
    proxySuccessMsg()       { return '✓ 系统代理已接管 → 127.0.0.1:7890'; },

    // ── DNS ──────────────────────────────────────────────────
    // ss -unl 不需要 root 权限，可见所有 UDP 监听端口（含 root 进程）
    checkDns1053()  { return !!run('ss -unl 2>/dev/null | grep :1053 || lsof -i UDP:1053 -n -P 2>/dev/null | grep -i mihomo'); },
    getDnsServers() { return []; },
    setDnsToMihomo() { throw new Error('不支持'); },
    async restoreAll() { throw new Error('平台不支持 DNS 管理'); },
    flushDns()        { run('resolvectl flush-caches 2>/dev/null || nscd -K 2>/dev/null || true'); },
    isDnsActive()     { return false; },
    printDnsStatus()  { console.log(c.yellow(`⚠ 当前平台 (${this.name}) 不支持 DNS 管理`)); },
    adminHint()       {},
    dnsOnSuccess(_iface) { console.log(c.dim('  关闭: mihomo-ctl dns-off')); },
    dnsOnErrorHint(_iface) {},

    // ── 升级 ─────────────────────────────────────────────────
    upgradeAsset(osName, arch, latest) {
      return {
        url:    `https://github.com/MetaCubeX/mihomo/releases/download/${latest}/mihomo-${osName}-${arch}-${latest}.gz`,
        tmpPkg: path.join(TMP, `mihomo-new-${latest}.gz`),
        tmpBin: path.join(TMP, `mihomo-new-${latest}`),
        bkBin:  path.join(TMP, `mihomo-old-${latest}`),
      };
    },
    extractAsset(tmpPkg, tmpBin) {
      run(`gunzip -f "${tmpPkg}"`);
      if (!fs.existsSync(tmpBin)) throw new Error('解压失败');
      run(`chmod +x "${tmpBin}"`);
    },
    installBin(tmpBin)  { execSync(`sudo mv "${tmpBin}" "${BIN}"`, { stdio: 'pipe' }); },
    backupBin(bkBin)    { if (fs.existsSync(BIN)) run(`sudo cp "${BIN}" "${bkBin}" 2>/dev/null`); },
    rollbackBin(bkBin)  { run(`sudo mv "${bkBin}" "${BIN}" 2>/dev/null || true`); },
    upgradeRollbackHint(bkBin) { return `sudo mv "${bkBin}" "${BIN}" && mihomo-ctl restart`; },
    installSelf(tmp, self, bak) {
      execSync(`sudo cp "${self}" "${bak}"`, { stdio: 'pipe' });
      execSync(`sudo mv "${tmp}" "${self}"`, { stdio: 'pipe' });
      execSync(`sudo chmod 755 "${self}"`, { stdio: 'pipe' });
    },
    selfRollbackHint(bak, self) { return `sudo mv "${bak}" "${self}"`; },
  };
}

const PLATFORM_ADAPTERS = {
  // ════════════════════════════════════════════════════════════
  //  macOS
  // ════════════════════════════════════════════════════════════
  macos: {
    name: 'macos', supportsProxy: true, supportsDns: true,

    // ── 进程 ──────────────────────────────────────────────────
    stopProcess() {
      run(`launchctl unload "${PLIST}" 2>/dev/null || true`);
      // sudo pkill 优先：覆盖 tun-on 以 root 启动的进程；普通 pkill 作为 fallback
      run(`sudo pkill -f 'mihomo -d' 2>/dev/null || pkill -f 'mihomo -d' 2>/dev/null || true`);
    },
    startProcess() {
      if (fs.existsSync(PLIST)) run(`launchctl load "${PLIST}" 2>/dev/null || true`);
      else exec(`${BIN} -d "${CONFIG_DIR}" >> "${LOG}" 2>&1 &`);
    },
    forceKill()  { run(`sudo pkill -KILL -f 'mihomo -d' 2>/dev/null || pkill -KILL -f 'mihomo -d' 2>/dev/null || true`); },
    getPid()     { return run("pgrep -f 'mihomo -d'"); },
    killHint()   { return 'sudo kill $(pgrep -f "mihomo -d")'; },
    port7890Ok() {
      // netstat -an 不需要 root 权限，可见所有监听端口（含 root 进程）
      if (run('netstat -an 2>/dev/null | grep "127.0.0.1.7890.*LISTEN"')) return true;
      // 普通模式 fallback（非 root 启动时）
      return !!run('lsof -i :7890 -sTCP:LISTEN -n 2>/dev/null | grep -i mihomo | head -1');
    },
    hasGit()     { return !!run('which git 2>/dev/null'); },
    gitNull:       '2>/dev/null',
    extraOfflineStatus() {
      const launchd = run('launchctl list | grep mihomo');
      if (launchd) console.log(c.yellow('  LaunchAgent 已加载但进程未响应 API'));
    },

    // ── 开机自启 ──────────────────────────────────────────────
    isAutostartEnabled() { return fs.existsSync(PLIST) && !fs.existsSync(PLIST_DISABLED); },
    enableAutostart() {
      if (fs.existsSync(PLIST_DISABLED)) fs.renameSync(PLIST_DISABLED, PLIST);
      else if (!fs.existsSync(PLIST)) throw new Error('plist 文件不存在，请重新安装');
      run(`launchctl load "${PLIST}" 2>/dev/null || true`);
      console.log(c.green('✓ 已启用开机自启'));
      console.log(c.dim(`  plist: ${PLIST}`));
    },
    disableAutostart() {
      if (fs.existsSync(PLIST) && !fs.existsSync(PLIST_DISABLED)) {
        run(`launchctl unload "${PLIST}" 2>/dev/null || true`);
        fs.renameSync(PLIST, PLIST_DISABLED);
      }
      console.log(c.dim('✓ 已禁用开机自启（当前进程不受影响）'));
      console.log(c.dim(`  plist 已更名为: ${PLIST_DISABLED}`));
    },

    // ── 系统代理 ──────────────────────────────────────────────
    getCurlProxyArg() {
      try {
        const sp = execSync('scutil --proxy 2>/dev/null', { encoding: 'utf8' });
        const httpsOn   = (sp.match(/HTTPSEnable\s*:\s*(\d+)/)  || [])[1] === '1';
        const httpsHost = (sp.match(/HTTPSProxy\s*:\s*(\S+)/)   || [])[1];
        const httpsPort = (sp.match(/HTTPSPort\s*:\s*(\d+)/)    || [])[1];
        if (httpsOn && httpsHost && httpsPort) return `-x "http://${httpsHost}:${httpsPort}"`;
        const socksOn   = (sp.match(/SOCKSEnable\s*:\s*(\d+)/) || [])[1] === '1';
        const socksHost = (sp.match(/SOCKSProxy\s*:\s*(\S+)/)  || [])[1];
        const socksPort = (sp.match(/SOCKSPort\s*:\s*(\d+)/)   || [])[1];
        if (socksOn && socksHost && socksPort) return `--socks5 "${socksHost}:${socksPort}"`;
      } catch {}
      return '';
    },
    isSystemProxyActive() {
      const out = run('scutil --proxy 2>/dev/null');
      return out.includes('HTTPProxy : 127.0.0.1') && out.includes('HTTPEnable : 1');
    },
    getActiveInterface() {
      const iface = run("route -n get default 2>/dev/null | awk '/interface:/{print $2}'").trim();
      if (iface) {
        const lines = run('networksetup -listallhardwareports 2>/dev/null').split('\n');
        let port = '';
        for (const line of lines) {
          const pm = line.match(/^Hardware Port:\s*(.+)/);
          if (pm) port = pm[1].trim();
          const dm = line.match(/^Device:\s*(.+)/);
          if (dm && dm[1].trim() === iface && port) return port;
        }
      }
      for (const svc of run('networksetup -listallnetworkservices').split('\n')
          .filter(s => s && !s.startsWith('An ') && !s.includes('*'))) {
        const info = run(`networksetup -getinfo "${svc}" 2>/dev/null`);
        const m = info.match(/^IP address:\s*(.+)$/m);
        if (m && m[1].trim() !== '(null)' && m[1].trim() !== '') return svc;
      }
      return 'Wi-Fi';
    },
    setSystemProxy(iface) {
      execSync(`sudo networksetup -setwebproxy "${iface}" 127.0.0.1 7890`, { stdio: ['inherit', 'pipe', 'pipe'] });
      execSync(`sudo networksetup -setsecurewebproxy "${iface}" 127.0.0.1 7890`, { stdio: ['inherit', 'pipe', 'pipe'] });
      execSync(`sudo networksetup -setsocksfirewallproxy "${iface}" 127.0.0.1 7890`, { stdio: ['inherit', 'pipe', 'pipe'] });
    },
    clearSystemProxy(iface) {
      execSync(`sudo networksetup -setwebproxystate "${iface}" off`, { stdio: ['inherit', 'pipe', 'pipe'] });
      execSync(`sudo networksetup -setsecurewebproxystate "${iface}" off`, { stdio: ['inherit', 'pipe', 'pipe'] });
      execSync(`sudo networksetup -setsocksfirewallproxystate "${iface}" off`, { stdio: ['inherit', 'pipe', 'pipe'] });
    },
    proxySuccessMsg(iface) { return `✓ 系统代理已接管 → 127.0.0.1:7890 (${iface})`; },

    // ── DNS ──────────────────────────────────────────────────
    // netstat -an 不需要 root 权限，可见所有进程的端口（含 tun-on 以 root 启动的进程）
    checkDns1053() {
      return !!run('netstat -an 2>/dev/null | grep "127\.0\.0\.1\.1053"') ||
             !!run('lsof -i UDP:1053 -n -P 2>/dev/null | grep -i mihomo');
    },
    getDnsServers(iface) {
      const out = run(`networksetup -getdnsservers "${iface}" 2>/dev/null`);
      return out.trim().split('\n').map(l => l.trim()).filter(l => l && !/aren't|There/i.test(l));
    },
    setDnsToMihomo(iface) {
      execSync(`sudo networksetup -setdnsservers "${iface}" 127.0.0.1`, { stdio: ['inherit', 'pipe', 'pipe'] });
    },
    async restoreAll(iface, _dnsToRestore) {
      // 始终清空手动 DNS，让系统回到 DHCP 自动分配。
      // 不恢复 dns-on 时保存的静态 IP：笔记本换网络后那个 IP 已失效，
      // 强制 restore 会导致 DNS 断网。
      execSync(`sudo networksetup -setdnsservers "${iface}" empty`, { stdio: 'inherit' });
      run('dscacheutil -flushcache 2>/dev/null || true');
      await new Promise(r => setTimeout(r, 300));
      execSync(`sudo pfctl -a 'com.apple/mihomo-dns' -F nat`, { stdio: 'inherit' });
      try { fs.unlinkSync(PF_CONF); } catch {}
      return 'DHCP 自动';
    },
    flushDns()        { run('dscacheutil -flushcache 2>/dev/null || true'); },
    isDnsActive(iface) { return this.getDnsServers(iface).includes('127.0.0.1'); },
    loadPfAnchor() {
      const conf = 'rdr on lo0 proto udp from any to 127.0.0.1 port 53 -> 127.0.0.1 port 1053\n'
                 + 'rdr on lo0 proto tcp from any to 127.0.0.1 port 53 -> 127.0.0.1 port 1053\n';
      fs.writeFileSync(PF_CONF, conf);
      execSync(`sudo pfctl -a 'com.apple/mihomo-dns' -f "${PF_CONF}"`, { stdio: ['inherit', 'pipe', 'pipe'] });
      execSync('sudo pfctl -e 2>/dev/null || true', { stdio: 'pipe' });
      if (!run(`sudo pfctl -a 'com.apple/mihomo-dns' -sn 2>/dev/null`).includes('1053'))
        throw new Error('pf anchor 规则加载后验证失败');
    },
    isPfAnchorActive() { return run(`sudo pfctl -a 'com.apple/mihomo-dns' -sn 2>/dev/null`).includes('1053'); },
    printDnsStatus(iface) {
      const servers    = this.getDnsServers(iface);
      const mihomoIsDns = servers.includes('127.0.0.1');
      const port1053   = this.checkDns1053();
      const pfOk       = this.isPfAnchorActive();
      console.log(`  接口       : ${c.cyan(iface)}`);
      console.log(`  系统 DNS   : ${c.cyan(servers.length ? servers.join(', ') : '(DHCP 自动)')}`);
      console.log(`  Mihomo 监听 1053 : ${port1053 ? c.green('✓') : c.red('✗')}`);
      console.log(`  pf rdr anchor    : ${pfOk ? c.green('✓ 已加载') : c.red('✗ 未加载')}`);
      if (pfOk && mihomoIsDns && port1053) console.log(`  接管状态 : ${c.green('已接管（防污染 DNS 生效）')}`);
      else if (mihomoIsDns && !pfOk)       console.log(`  接管状态 : ${c.yellow('⚠ 系统 DNS=127.0.0.1 但 pf 规则未加载，运行 dns-on 修复')}`);
      else                                 console.log(`  接管状态 : ${c.dim('未接管（使用默认 DNS）')}`);
      const r = run('dig +short +time=2 cloudflare.com @127.0.0.1 -p 1053 2>/dev/null');
      console.log(`  实际解析测试 : ${r ? c.green('✓ ' + r.split('\n')[0]) : c.red('✗ 无响应')}`);
      if (!pfOk && mihomoIsDns) {
        console.log(c.dim('\n  pf anchor 已丢失（常见于睡眠/唤醒后），运行:'));
        console.log(c.cyan('  mihomo-ctl dns-on'));
