// ─── 命令：tun-on / tun-off ──────────────────────────────────
function setTunEnable(cfgText, enable) {
  const tunIdx    = cfgText.indexOf('\ntun:\n');
  if (tunIdx === -1) return null;
  const enableIdx = cfgText.indexOf('\n  enable:', tunIdx);
  if (enableIdx === -1) return null;
  const lineEnd   = cfgText.indexOf('\n', enableIdx + 1);
  const line      = cfgText.slice(enableIdx, lineEnd);
  const newLine   = line.replace(/(enable:\s*)(true|false)/, `$1${enable}`);
  return cfgText.slice(0, enableIdx) + newLine + cfgText.slice(lineEnd);
}

async function cmdTunOn() {
  // Windows：需管理员权限（WinTun 驱动）—— 非管理员时自动 UAC 提权重运
  if (P.name === 'windows') {
    let isAdmin = false;
    try { execSync('net session', { stdio: 'pipe' }); isAdmin = true; } catch {}
    if (!isAdmin) { winElevate('tun-on'); return; }
  }
  if (!(await isRunning())) { console.log(c.red('请先启动 Mihomo: mihomo-ctl start')); return; }
  const cfgText = fs.readFileSync(CONFIG, 'utf8');
  const tunIdx  = cfgText.indexOf('\ntun:\n');
  if (tunIdx === -1) { console.log(c.red('✗ 配置中缺少 tun: 块，请检查 config.yaml')); return; }
  const enableIdx = cfgText.indexOf('\n  enable:', tunIdx);
  const lineEnd   = cfgText.indexOf('\n', enableIdx + 1);
  if (/enable:\s*true/.test(cfgText.slice(enableIdx, lineEnd))) {
    // yaml 已是 true，但运行中进程是否真的加载了 TUN？
    const runCfg = await apiGet('/configs').catch(() => ({}));
    if (runCfg.tun?.enable === true) { console.log(c.green('✓ TUN 已处于开启状态')); return; }
    console.log(c.dim('  TUN 配置已启用但运行中进程未加载（可能存在遗留进程），正在重启...'));
  }
  const newCfg = setTunEnable(cfgText, 'true');
  fs.writeFileSync(CONFIG, newCfg);
  console.log(c.bold('\n── 开启 TUN 透明代理 ─────────────────────────────'));
  // 先停止旧进程；macOS 额外 unload LaunchAgent
  if (P.name === 'macos') run(`launchctl unload "${PLIST}" 2>/dev/null || true`);
  P.stopProcess();
  P.forceKill();
  await new Promise(r => setTimeout(r, 1200));
  if (P.name === 'windows') {
    // 已是管理员：直接启动（WinTun 驱动权限由管理员保证）
    console.log(c.dim('  以管理员权限启动（TUN 需 WinTun 驱动）...'));
    spawn(BIN, ['-d', CONFIG_DIR], { detached: true, stdio: 'ignore', windowsHide: true }).unref();
  } else {
    console.log(c.dim('  以 sudo 启动（TUN auto-route 需 root 权限）...'));
    spawn('sudo', [BIN, '-d', CONFIG_DIR], { detached: true, stdio: 'ignore' }).unref();
  }
  await new Promise(r => setTimeout(r, 2000));
  if (await isRunning()) {
    fs.writeFileSync(TUN_STATE_FILE, '1');
