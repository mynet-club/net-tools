async function cmdTunOff() {
  // Windows：需管理员权限（taskkill 掉管理员进程）—— 非管理员时自动 UAC 提权重运
  if (P.name === 'windows') {
    let isAdmin = false;
    try { execSync('net session', { stdio: 'pipe' }); isAdmin = true; } catch {}
    if (!isAdmin) { winElevate('tun-off'); return; }
  }
  let cfgText = fs.readFileSync(CONFIG, 'utf8');
  const newCfg = setTunEnable(cfgText, 'false');
  if (newCfg) fs.writeFileSync(CONFIG, newCfg);
  console.log(c.bold('\n── 关闭 TUN 透明代理 ─────────────────────────────────────────────────────────'));
  // 通过适配器停止进程，覆盖 root/admin 启动的进程
  P.stopProcess();
  P.forceKill();
  try { fs.unlinkSync(TUN_STATE_FILE); } catch {}
  if (P.name === 'macos') {
    // macOS：startProcess 异步不可靠，提示用户手动 start
    console.log(c.green('✓ TUN 模式已关闭'));
    console.log(c.yellow('  请等待约 10 秒后运行: mihomo-ctl start'));
  } else {
    // Linux/Alpine/Windows：startProcess() 同步可验证
    P.startProcess();
    await new Promise(r => setTimeout(r, 1000));
    if (await isRunning()) {
      console.log(c.green('✓ TUN 模式已关闭'));
      console.log(c.dim('  Mihomo 已恢复普通模式（系统代理）'));
    } else {
      console.log(c.yellow('⚠ TUN 已关闭，请手动启动: mihomo-ctl start'));
    }
  }
}

